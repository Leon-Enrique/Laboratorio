# Ejemplo Nginx — /etc/nginx/sites-available/genotipia
# sudo ln -s ... sites-enabled/  &&  sudo nginx -t  &&  sudo systemctl reload nginx

# Sitio Angular (frontend)
server {
    listen 80;
    server_name genotipia.com www.genotipia.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name genotipia.com www.genotipia.com;

    # ssl_certificate /etc/letsencrypt/live/genotipia.com/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/genotipia.com/privkey.pem;

    root /var/www/genotipia;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }
}

# API FastAPI
server {
    listen 80;
    server_name api.genotipia.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name api.genotipia.com;

    # ssl_certificate ...

    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
