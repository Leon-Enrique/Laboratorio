# Ejemplo systemd para Linux (VPS).
# 1. Copiar a /etc/systemd/system/genotipia-api.service
# 2. Editar rutas y usuario
# 3. sudo systemctl daemon-reload && sudo systemctl enable --now genotipia-api

[Unit]
Description=Genotipia API (FastAPI)
After=network.target postgresql.service

[Service]
User=www-data
Group=www-data
WorkingDirectory=/opt/Laboratorio/laboratorio-bioquimica-backend
EnvironmentFile=/opt/Laboratorio/laboratorio-bioquimica-backend/.env
ExecStart=/opt/Laboratorio/laboratorio-bioquimica-backend/venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
