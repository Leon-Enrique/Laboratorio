# Copiar en el servidor como .env (NO subir a GitHub)
# cp .env.production.example .env  &&  editar valores reales

APP_ENV=production

# PostgreSQL en el mismo VPS o servicio gestionado
DATABASE_URL=postgresql://genotipia_user:CAMBIAR_CLAVE@localhost:5432/laboratorio_db

# Generar clave larga: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CAMBIAR_POR_CLAVE_LARGA_Y_UNICA

# Sitio público y API (HTTPS en producción)
FRONTEND_URL=https://genotipia-lab.com
API_PUBLIC_URL=https://api.genotipia-lab.com
PUBLIC_SITE_URL=https://genotipia-lab.com

# Solo orígenes que usarán la web (separados por coma)
CORS_ORIGINS=https://genotipia-lab.com,https://www.genotipia-lab.com

# En producción: migrar en deploy, no en cada arranque del proceso
AUTO_MIGRATE=false
RUN_LEGACY_SCHEMA_PATCHES=false
RUN_DATA_BACKFILL=true
