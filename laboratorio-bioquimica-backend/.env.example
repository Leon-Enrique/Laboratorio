# Entorno: development | production
APP_ENV=development

# ─── Login del panel (/login) — LEE ESTO ───────────────────
# El usuario y contraseña del panel NO se guardan aquí en local.
# Local (desarrollo): email admin@laboratorio.com  contraseña admin123
#   → Se crean al ejecutar: python run_init_db.py
#   → También documentado en README.md (sección Credenciales demo)
# Internet (producción): TÚ eliges la clave y la pones abajo ANTES de run_init_db.py
# ADMIN_INITIAL_PASSWORD=tu_clave_fuerte_minimo_12_caracteres

# PostgreSQL (producción) o sqlite (solo desarrollo local)
DATABASE_URL=postgresql://postgres:password@localhost:5432/laboratorio_db

# Seguridad — obligatorio cambiar en producción
SECRET_KEY=cambia_esta_clave_por_una_segura_larga

# URLs públicas (PDF, QR, portal)
FRONTEND_URL=http://localhost:4200
API_PUBLIC_URL=http://localhost:8000
# Dominio real del sitio (QR en PDF/comprobantes — no usar localhost)
PUBLIC_SITE_URL=https://genotipia-lab.com

# CORS — orígenes separados por coma (producción: https://tudominio.com)
# CORS_ORIGINS=https://genotipia-lab.com,https://www.genotipia-lab.com

# Migraciones al arrancar (dev: true, prod: false — usar alembic upgrade head en deploy)
AUTO_MIGRATE=true
RUN_LEGACY_SCHEMA_PATCHES=true
RUN_DATA_BACKFILL=true

# Producción recomendado:
# APP_ENV=production
# AUTO_MIGRATE=false
# RUN_LEGACY_SCHEMA_PATCHES=false
