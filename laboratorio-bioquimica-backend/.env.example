# Entorno: development | production
APP_ENV=development

# PostgreSQL (producción) o sqlite (solo desarrollo local)
DATABASE_URL=postgresql://postgres:password@localhost:5432/laboratorio_db

# Seguridad — obligatorio cambiar en producción
SECRET_KEY=cambia_esta_clave_por_una_segura_larga

# URLs públicas (PDF, QR, portal)
FRONTEND_URL=http://localhost:4200
API_PUBLIC_URL=http://localhost:8000

# CORS — orígenes separados por coma (producción: https://tudominio.com)
# CORS_ORIGINS=https://genotipia.com,https://www.genotipia.com

# Migraciones al arrancar (dev: true, prod: false — usar alembic upgrade head en deploy)
AUTO_MIGRATE=true
RUN_LEGACY_SCHEMA_PATCHES=true
RUN_DATA_BACKFILL=true

# Producción recomendado:
# APP_ENV=production
# AUTO_MIGRATE=false
# RUN_LEGACY_SCHEMA_PATCHES=false
