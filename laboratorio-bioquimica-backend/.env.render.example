# Variables para Render (Web Service genotipia-api) — demo gratis con Neon
# Copie estos valores en Render → Environment (no subir .env a GitHub)

APP_ENV=production

# Neon → Connection string (incluya ?sslmode=require)
DATABASE_URL=postgresql://usuario:clave@ep-xxx.neon.tech/neondb?sslmode=require

# Render puede generar SECRET_KEY automáticamente (render.yaml) o use:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CAMBIAR_POR_CLAVE_LARGA

# Deben coincidir con su proyecto Vercel (ver environment.production.ts)
FRONTEND_URL=https://genotipia-lab.vercel.app
API_PUBLIC_URL=https://genotipia-api.onrender.com
PUBLIC_SITE_URL=https://genotipia-lab.vercel.app
CORS_ORIGINS=https://genotipia-lab.vercel.app

# Primera vez en BD vacía: crear tablas al arrancar
AUTO_MIGRATE=true
RUN_LEGACY_SCHEMA_PATCHES=true
# Sin datos de su PC — solo estructura; luego ejecute run_init_db.py en Shell
RUN_DATA_BACKFILL=false
